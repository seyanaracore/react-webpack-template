{
  "include": [".eslintrc.js", ".prettierrc.js", "webpack.config.ts", "./config/build"],
  "compilerOptions": {
    "types": ["webpack", "node"],
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES5",
    "baseUrl": "./",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true
  }
}
